// CI/CD pipeline for the AImodel microservice (monorepo: pidev_4SAE11).
// Script Path in Jenkins: backEnd/Microservices/AImodel/Jenkinsfile
// Credentials: GithubCredentials (SCM), DockerHubCrendentials (push), SonarQube (server with SonarQube Token).
// Prometheus: set PROMETHEUS_PUSHGATEWAY_URL (e.g. http://192.168.1.13:9091) to push build metrics.
pipeline {
    agent any

    environment {
        AIMODEL_DIR = 'backEnd/Microservices/AImodel'
        DOCKER_IMAGE = 'ridhaferchichi/aimodel-microservice'
        DOCKER_TAG = "${env.BUILD_NUMBER ?: 'latest'}"
        JOB_NAME_SAFE = "${env.JOB_NAME?.replaceAll('[^a-zA-Z0-9]', '_') ?: 'aimodel'}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                dir(AIMODEL_DIR) {
                    sh 'if [ -f mvnw ]; then chmod +x mvnw && ./mvnw clean verify -B; else mvn clean verify -B; fi'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${AIMODEL_DIR}/target/surefire-reports/**/*.xml, ${AIMODEL_DIR}/target/failsafe-reports/**/*.xml, ${AIMODEL_DIR}/target/*-reports/**/*.xml, ${AIMODEL_DIR}/build/test-results/**/*.xml, ${AIMODEL_DIR}/coverage/test-results/**/*.xml, ${AIMODEL_DIR}/test-results/**/*.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir(AIMODEL_DIR) {
                    withCredentials([string(credentialsId: 'SonarQubeToken', variable: 'SONAR_TOKEN')]) {
                        withSonarQubeEnv('SonarQube') {
                            sh '''
                              set +e
                              JACOCO_REPORTS=$(find . -type f -name "jacoco*.xml" -print 2>/dev/null | sed 's#^\\./##' | paste -sd, -)
                              JUNIT_REPORTS=$(find . -type f \\( -path "./target/surefire-reports/*.xml" -o -path "./target/surefire-reports/**/*.xml" -o -path "./target/failsafe-reports/*.xml" -o -path "./target/failsafe-reports/**/*.xml" -o -path "./target/*-reports/*.xml" -o -path "./target/*-reports/**/*.xml" -o -path "./build/test-results/*.xml" -o -path "./build/test-results/**/*.xml" -o -path "./coverage/test-results/*.xml" -o -path "./coverage/test-results/**/*.xml" -o -path "./test-results/*.xml" -o -path "./test-results/**/*.xml" \\) -print 2>/dev/null | sed 's#^\\./##' | paste -sd, -)
                              set -e

                              COVERAGE_ARG=""
                              if [ -n "$JACOCO_REPORTS" ]; then
                                COVERAGE_ARG="-Dsonar.coverage.jacoco.xmlReportPaths=$JACOCO_REPORTS"
                              fi
                              JUNIT_ARG=""
                              if [ -n "$JUNIT_REPORTS" ]; then
                                JUNIT_ARG="-Dsonar.junit.reportPaths=$JUNIT_REPORTS"
                              fi

                              if [ -f mvnw ]; then
                                chmod +x mvnw
                                ./mvnw -B sonar:sonar -Dsonar.projectKey=aimodel -Dsonar.projectName=AImodel $COVERAGE_ARG $JUNIT_ARG -Dsonar.token=$SONAR_TOKEN
                              else
                                mvn -B sonar:sonar -Dsonar.projectKey=aimodel -Dsonar.projectName=AImodel $COVERAGE_ARG $JUNIT_ARG -Dsonar.token=$SONAR_TOKEN
                              fi
                            '''
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                dir(AIMODEL_DIR) {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        timeout(time: 10, unit: 'SECONDS') {
                            waitForQualityGate abortPipeline: false
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir(AIMODEL_DIR) {
                    script {
                        docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                    }
                }
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'DockerHubCrendentials') {
                        def image = docker.image("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if (env.PROMETHEUS_PUSHGATEWAY_URL?.trim()) {
                    def status = currentBuild.result == 'SUCCESS' ? 1 : 0
                    def duration = (System.currentTimeMillis() - currentBuild.startTimeInMillis) / 1000.0
                    writeFile file: 'prometheus_metrics.txt', text: """# HELP jenkins_build_result Build result (1=success, 0=failure)
# TYPE jenkins_build_result gauge
jenkins_build_result{job="${JOB_NAME_SAFE}",build_number="${env.BUILD_NUMBER}"} ${status}
# HELP jenkins_build_duration_seconds Build duration in seconds
# TYPE jenkins_build_duration_seconds gauge
jenkins_build_duration_seconds{job="${JOB_NAME_SAFE}",build_number="${env.BUILD_NUMBER}"} ${duration}
"""
                    sh "curl -s --data-binary @prometheus_metrics.txt '${env.PROMETHEUS_PUSHGATEWAY_URL}/metrics/job/${JOB_NAME_SAFE}/instance/${env.BUILD_NUMBER}' || true"
                }
            }
            cleanWs()
        }
        failure {
            echo 'Pipeline failed'
        }
        success {
            echo 'Pipeline succeeded'
        }
    }
}
