node {
    checkout scm
    def apiUrl = (params.PUBLIC_API_GATEWAY_URL?.toString()?.trim()) ?: 'http://api.smartfreelance.example.com'
    load('ci/pipelines/microservicePipeline.groovy').runMicroservicePipeline([
        servicePath: 'frontend/smart-freelance-app',
        imageName: 'frontend',
        dockerBuildArgs: "--build-arg API_GATEWAY_PUBLIC_URL=${apiUrl}"
    ])
}
